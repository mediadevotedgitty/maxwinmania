# Get these from https://sanity.io/manage → your project → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Create a token at sanity.io/manage → your project → API → Tokens
# Give it "Editor" permissions
SANITY_API_TOKEN=your_token_here

# Any random string — used to secure the revalidation webhook
REVALIDATE_SECRET=your_random_secret_here

# Mailjet — get these from app.mailjet.com → Account Settings → API Key Management
MJ_APIKEY_PUBLIC=your_mailjet_public_key
MJ_APIKEY_PRIVATE=your_mailjet_private_key
# The numeric ID of your Mailjet contact list
MJ_CONTACT_LIST_ID=your_list_id
